<persistence xmlns="https://jakarta.ee/xml/ns/persistence" version="3.1">
    <persistence-unit name="feedbookPU">
        <provider>org.hibernate.jpa.HibernatePersistenceProvider</provider>

        <class>com.example.feedbook.entity.User</class>
        <class>com.example.feedbook.entity.Post</class>
        <class>com.example.feedbook.entity.Comment</class>
        <class>com.example.feedbook.entity.Group</class>
        <class>com.example.feedbook.entity.GroupMember</class>
        <class>com.example.feedbook.entity.Follow</class>

        <properties>
            <property name="jakarta.persistence.jdbc.url" value="jdbc:postgresql://localhost:5432/feedbook"/>
            <property name="jakarta.persistence.jdbc.user" value="postgres"/>
            <!-- TODO: Replace YOUR_PASSWORD_HERE with your local PostgreSQL password -->
            <property name="jakarta.persistence.jdbc.password" value="YOUR_PASSWORD_HERE"/>

            <property name="hibernate.hbm2ddl.auto" value="update"/>
            <property name="hibernate.show_sql" value="true"/>
        </properties>
    </persistence-unit>

</persistence>
